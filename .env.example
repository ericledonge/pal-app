# Clés publiques embarquées dans le bundle (préfixe EXPO_PUBLIC_).
# Copier ce fichier vers .env (gitignoré) et renseigner les valeurs.
# En dev (__DEV__), Sentry et Amplitude sont désactivés : aucun envoi réseau.
# En prod, ces clés sont fournies par eas.json (env de chaque profil de build).

# Feedback (Web3Forms) — clé d'accès publique
EXPO_PUBLIC_WEB3FORMS_KEY=

# Sentry — DSN du projet (valeur publique). Active le suivi d'erreurs + détection de casse du parser.
EXPO_PUBLIC_SENTRY_DSN=

# Amplitude — clé d'API du projet. Active l'analytics produit.
EXPO_PUBLIC_AMPLITUDE_KEY=
