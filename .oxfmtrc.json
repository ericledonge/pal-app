{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": false,
  "semi": true,
  "trailingComma": "all",
  "sortImports": {
    "order": "asc"
  },
  "ignorePatterns": [
    "design/**",
    "docs/**",
    "**/*.md",
    "package-lock.json",
    ".rnstorybook/**",
    "**/__tests__/fixtures/**"
  ]
}
