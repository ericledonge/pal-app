{
  "expo": {
    "name": "Pickleball Action Lévis",
    "slug": "pal-app",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a7e248cd-790d-46df-9b58-565a9f0841a6",
      "checkAutomatically": "NEVER"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "palevis",
    "userInterfaceStyle": "automatic",
    "platforms": ["ios", "android"],
    "ios": {
      "bundleIdentifier": "ca.palevis.app",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ca.palevis.app",
      "adaptiveIcon": {
        "backgroundColor": "#0b1326",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["SCHEDULE_EXACT_ALARM"]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f8f9fb",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0b1326",
            "image": "./assets/images/splash-icon.png"
          }
        }
      ],
      "@sentry/react-native",
      "expo-audio",
      [
        "expo-notifications",
        {
          "color": "#ff5700",
          "sounds": ["./assets/sounds/match-end.wav"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a7e248cd-790d-46df-9b58-565a9f0841a6"
      }
    },
    "owner": "eledonge"
  }
}
