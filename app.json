{
  "expo": {
    "name": "Pickleball Action Lévis",
    "slug": "pal-app",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "palevis",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "ca.palevis.app",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ca.palevis.app",
      "adaptiveIcon": {
        "backgroundColor": "#0b1326",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f8f9fb",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0b1326",
            "image": "./assets/images/splash-icon.png"
          }
        }
      ],
      "@sentry/react-native",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a7e248cd-790d-46df-9b58-565a9f0841a6"
      }
    },
    "owner": "eledonge"
  }
}
